# Copy this file to .env for local development.
# .env is gitignored and must never contain real secrets.

# Used by compose.yaml to configure the PostgreSQL container
POSTGRES_DB=mini_wsa
POSTGRES_USER=mini_wsa
POSTGRES_PASSWORD=mini_wsa_dev

# Used by application.yml to configure the Spring Boot datasource
DB_URL=jdbc:postgresql://localhost:5432/mini_wsa
DB_USERNAME=mini_wsa
DB_PASSWORD=mini_wsa_dev